<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS (thư mục dist sau npm run build)

  1) URL Rewrite Module (x64)
  2) Application Request Routing (ARR) — bắt buộc để proxy tới Node
     - Cài ARR (x64), rồi BẬT PROXY MỘT LẦN ở cấp SERVER:
       IIS → (chọn máy chủ, không phải site) → Application Request Routing Cache
       → Server Proxy Settings… → Enable proxy ✓

  API Node mặc định: http://127.0.0.1:4000 (sửa trong rule <action> nếu đổi API_PORT)
  Frontend build: VITE_API_BASE_URL=/api/v1 (cùng host với IIS → không cần CORS tách origin)

  SSE (/api/v1/monitor/stream): nếu stream bị treo, trong ARR thử tắt buffering cho upstream hoặc responseBufferLimit.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Ưu tiên 1: chuyển mọi /api/... sang Node Express -->
        <rule name="EduMonitor API reverse proxy" stopProcessing="true">
          <match url="^api(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4000/api{R:1}" />
        </rule>
        <!-- Ưu tiên 2: SPA — /login, /teachers, ... → index.html -->
        <rule name="EduMonitor SPA" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Không đẩy /api/* về index.html nếu rule proxy lỗi / thiếu ARR -->
            <add input="{REQUEST_URI}" pattern="^/api(/|$)" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
