API_PORT=4000
# Lắng nghe mọi NIC (mặc định). Chỉ localhost: API_HOST=127.0.0.1
API_HOST=0.0.0.0
# Khi Node nằm sau IIS (web.config reverse proxy /api → 127.0.0.1:4000): bật true
TRUST_PROXY=false

DB_SERVER=127.0.0.1
# Instance mặc định thường là 1433. Không dùng 1434 (đó là UDP Browser).
# SQL Express / named instance: xem TCP Dynamic Port trong SQL Server Configuration Manager,
# hoặc DB_SERVER=127.0.0.1\\SQLEXPRESS và bật SQL Server Browser.
DB_PORT=1433
DB_NAME=TruongHocViet
# Login failed for user 'sa': bật Mixed Mode + ENABLE sa + đúng mật khẩu,
# hoặc tạo login khác — xem database/04_cau_hinh_dang_nhap_sql_cho_api.sql
DB_USER=sa
DB_PASSWORD=your_password

# For local SQL Server, these values usually work
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true
# (ms) ECONNRESET/timeout: thử tăng; kiểm tra TCP/IP + firewall SQL
# DB_CONNECT_TIMEOUT=30000
# DB_REQUEST_TIMEOUT=60000
# Windows: Node dùng ODBC + đăng nhập Windows (tài khoản chạy npm run api cần quyền trên DB)
# DB_WINDOWS_AUTH=false

JWT_ACCESS_SECRET=replace_this_access_secret
JWT_REFRESH_SECRET=replace_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# * = phản chiếu Origin (tiện LAN). Production nên liệt kê: https://ten-mien,http://IP:5173
CORS_ORIGIN=http://localhost:5173
SIMULATION_TICK_MS=15000

# Gọi API:
# - Dev + proxy Vite (khuyến nghị): VITE_API_BASE_URL=/api/v1  (npm run dev, API chạy cổng 4000)
# - SPA và API cùng IIS (reverse proxy /api -> Node): build với VITE_API_BASE_URL=/api/v1
# - API riêng cổng / máy khác: VITE_API_BASE_URL=http://IP-HOAC-TEN:4000/api/v1 rồi npm run build
VITE_API_BASE_URL=/api/v1

# --- Roboflow Inference (nhận diện tập trung — chỉ server Node, không VITE_) ---
ROBOFLOW_FOCUS_ENABLED=true
ROBOFLOW_INFERENCE_URL=http://127.0.0.1:9001
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=dao-tmqly
ROBOFLOW_WORKFLOW_ID=student-focus-monitor-1778252522047
# ECONNREFUSED 127.0.0.1:9001 = chưa bật Inference local — chọn một trong các cách:
# (A) Inference trên máy chạy `npm run api`: `inference server start` — kiểm tra: npm run probe-roboflow
# (B) Inference máy LAN: ROBOFLOW_INFERENCE_URL=http://192.168.x.x:9001
# (C) Không dùng cổng 9001 — Roboflow Serverless Hosted API (+ API key trong Roboflow):
# ROBOFLOW_INFERENCE_URL=https://serverless.roboflow.com
# (D) Giữ localhost, khi không kết nối được cổng 9001 thì gọi serverless (phải có API key):
# ROBOFLOW_HOSTED_FALLBACK=true
# ROBOFLOW_SERVERLESS_URL=https://serverless.roboflow.com
# ROBOFLOW_FETCH_TIMEOUT_MS=120000
# ROBOFLOW_IMAGE_INPUT_NAME=image
# ROBOFLOW_INFER_WORKFLOW_URL=http://127.0.0.1:9001/infer/workflows/dao-tmqly/student-focus-monitor-1778252522047
