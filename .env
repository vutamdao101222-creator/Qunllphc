API_PORT=4000
API_HOST=0.0.0.0

# ── SQL Server (instance MSSQL$BINMILO) ── TCP cố định 1436, SQL login sa
# Tương đương: sqlcmd -S "BINMILO,1436" hoặc "127.0.0.1,1436" -U sa -P "..." -b -C
# Node chạy trên cùng máy SQL → chỉ máy chủ cần mở 1436; điện thoại chỉ gọi HTTP API (4000/IIS).
DB_SERVER=BINMILO
DB_PORT=1436
DB_NAME=TruongHocViet
DB_USER=sa
DB_PASSWORD=Sa12345!
DB_AUTO_MIGRATE=true

DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

JWT_ACCESS_SECRET=replace_this_access_secret
JWT_REFRESH_SECRET=replace_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=*
SIMULATION_TICK_MS=15000

# Điện thoại cùng Wi‑Fi: dùng app build + gọi http://IP_MÁY:4000/... Hoặc Vite dev: npm run dev (host LAN).
VITE_API_BASE_URL=/api/v1
