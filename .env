API_PORT=4000
API_HOST=0.0.0.0

# ── SQL Server (instance MSSQL$BINMILO) ── TCP cố định 1436, SQL login sa
# Tương đương: sqlcmd -S "BINMILO,1436" hoặc "127.0.0.1,1436" -U sa -P "..." -b -C
# Node chạy trên cùng máy SQL → chỉ máy chủ cần mở 1436; điện thoại chỉ gọi HTTP API (4000/IIS).
DB_SERVER=BINMILO
DB_PORT=1436
DB_NAME=TruongHocViet
DB_USER=sa
DB_PASSWORD=Sa12345!
DB_AUTO_MIGRATE=true

DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

JWT_ACCESS_SECRET=replace_this_access_secret
JWT_REFRESH_SECRET=replace_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=*
SIMULATION_TICK_MS=15000

# Điện thoại cùng Wi‑Fi: dùng app build + gọi http://IP_MÁY:4000/... Hoặc Vite dev: npm run dev (host LAN).
VITE_API_BASE_URL=/api/v1

# ── Roboflow (AI tập trung) — không khai báo → mặc định gọi 127.0.0.1:9001 (cần Inference đang chạy).
# Demo không cần cổng 9001 (JSON giả — tắt khi đã bật Inference thật):
ROBOFLOW_MOCK_FOCUS=false
# Khi có Inference local: đặt ROBOFLOW_MOCK_FOCUS=false rồi trên máy chạy npm run api: inference server start
# Hoặc Inference máy khác: ROBOFLOW_INFERENCE_URL=http://IP-LAN:9001
# Cloud Roboflow (cần key): ROBOFLOW_INFERENCE_URL=https://serverless.roboflow.com + ROBOFLOW_API_KEY=...
# ROBOFLOW_WORKSPACE=dao-tmqly
# ROBOFLOW_WORKFLOW_ID=student-focus-monitor-1778252522047
